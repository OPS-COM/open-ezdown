{
  "manifest_version": 3,
  "name": "EZDown Link Extractor",
  "version": "1.0",
  "description": "Extract streaming links using yt-dlp",
  "permissions": [
    "activeTab",
    "cookies",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "http://localhost:3002/*",
    "http://localhost:3003/*",
    "http://localhost:3004/*",
    "http://localhost:3005/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["supported-domains.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "EZDown",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
